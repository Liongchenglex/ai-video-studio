# Database
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# BetterAuth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=ai-video-studio

# Anthropic (Claude Vision)
ANTHROPIC_API_KEY=your-anthropic-key

# fal.ai (FLUX.1 Kontext)
FAL_KEY=your-fal-key

# Inngest (background jobs: batch Generate all, music)
# Local dev: INNGEST_DEV=1 runs against `npx inngest-cli dev` with signature
# verification off. NEVER set INNGEST_DEV in production.
# Production: BOTH keys are REQUIRED. The SDK fails closed (serve() throws)
# if the signing key is missing in prod mode, and signed requests are the
# only thing preventing unauthenticated /api/inngest calls from spending
# paid fal.ai credits on arbitrary projects.
INNGEST_DEV=1
INNGEST_SIGNING_KEY=your-inngest-signing-key   # required in production
INNGEST_EVENT_KEY=your-inngest-event-key       # required in production
